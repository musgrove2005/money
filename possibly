#!/usr/bin/env python3
"""
Options Strategy Scanner (Enhanced)
====================================
New in this version:
  - Unusual Whales flow sentiment  (set UNUSUAL_WHALES_API_KEY env var)
  - IV Rank / IV Percentile        (vs 1-year rolling HV range)
  - Earnings awareness             (warns when expiry straddles an earnings event)
  - Full Greeks: gamma, theta, vega on every leg + net per strategy
  - Bid/ask spread quality score   (tight / ok / wide)
  - Backtest: 1-year iron condor win-rate simulation

Setup:
    pip install yfinance pandas numpy requests

Usage:
    python possibly AAPL
    python possibly SPY --dte 45
    python possibly NVDA --expiry 2026-07-17
    UNUSUAL_WHALES_API_KEY=xxx python possibly AAPL
"""

import argparse
import math
import os
import sys
from datetime import date, datetime

import numpy as np
import pandas as pd

try:
    import yfinance as yf
except ImportError:
    sys.exit("Missing dependency. Run:  pip install yfinance pandas numpy requests")

try:
    import requests as _requests
    HAS_REQUESTS = True
except ImportError:
    HAS_REQUESTS = False

TRADING_DAYS = 252
SEP = "-" * 72
UW_API_BASE = "https://api.unusualwhales.com"


# ---------------------------------------------------------------------------
# Black-Scholes -- full Greeks
# ---------------------------------------------------------------------------

def _norm_cdf(x):
    return 0.5 * (1.0 + math.erf(x / math.sqrt(2.0)))


def _norm_pdf(x):
    return math.exp(-0.5 * x * x) / math.sqrt(2.0 * math.pi)


def _bs_price(spot, strike, t, iv, rfr, kind):
    """Black-Scholes theoretical price."""
    try:
        if t <= 0 or iv <= 0:
            return 0.0
        d1 = (math.log(spot / strike) + (rfr + 0.5 * iv * iv) * t) / (iv * math.sqrt(t))
        d2 = d1 - iv * math.sqrt(t)
        disc = math.exp(-rfr * t)
        if kind == "call":
            return spot * _norm_cdf(d1) - strike * disc * _norm_cdf(d2)
        return strike * disc * _norm_cdf(-d2) - spot * _norm_cdf(-d1)
    except (ValueError, ZeroDivisionError, OverflowError):
        return 0.0


def bs_greeks(spot, strike, t_years, iv, rfr, kind):
    """
    Full Black-Scholes Greeks.
    Returns dict with delta, gamma, theta ($/share/day), vega ($/share per 1% IV).
    Returns {} on bad inputs.
    """
    try:
        if t_years <= 0 or iv <= 0 or strike <= 0 or spot <= 0:
            return {}
        d1 = (math.log(spot / strike) + (rfr + 0.5 * iv * iv) * t_years) / (
            iv * math.sqrt(t_years))
        d2 = d1 - iv * math.sqrt(t_years)
        nd1 = _norm_pdf(d1)
        sqrt_t = math.sqrt(t_years)
        disc = math.exp(-rfr * t_years)

        delta = _norm_cdf(d1) if kind == "call" else _norm_cdf(d1) - 1.0
        gamma = nd1 / (spot * iv * sqrt_t)
        vega = spot * nd1 * sqrt_t / 100.0          # per 1% IV move, per share
        if kind == "call":
            theta = (-(spot * nd1 * iv) / (2 * sqrt_t)
                     - rfr * strike * disc * _norm_cdf(d2)) / 365.0
        else:
            theta = (-(spot * nd1 * iv) / (2 * sqrt_t)
                     + rfr * strike * disc * _norm_cdf(-d2)) / 365.0

        return {"delta": delta, "gamma": gamma, "theta": theta, "vega": vega}
    except (ValueError, ZeroDivisionError, OverflowError):
        return {}


