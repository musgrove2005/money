def get_risk_free_rate():
    try:
        px = yf.Ticker("^IRX").history(period="5d")["Close"].dropna()
        if len(px):
            return float(px.iloc[-1]) / 100.0
    except Exception:
        pass
    return 0.045


def fetch_underlying(ticker):
    tk = yf.Ticker(ticker)
    hist = tk.history(period="1y")
    if hist.empty:
        sys.exit(f"No price history found for '{ticker}'. Check the symbol.")
    closes = hist["Close"].dropna()
    spot = float(closes.iloc[-1])
    rets = np.log(closes / closes.shift(1)).dropna()
    hv_30 = float(rets.tail(21).std() * math.sqrt(TRADING_DAYS))
    hv_1y = float(rets.std() * math.sqrt(TRADING_DAYS))
    sma50 = float(closes.tail(50).mean())
    expiries = list(tk.options or [])
    if not expiries:
        sys.exit(f"'{ticker}' has no listed options on Yahoo Finance.")
    return tk, spot, hv_30, hv_1y, sma50, closes, expiries


def get_iv_rank(closes, current_iv):
    """
    IV Rank and IV Percentile vs 1-year rolling 30d realized vol.
    Uses HV as an IV proxy -- conservative but practical without historical IV data.
    Returns (iv_rank, iv_percentile).
    """
    rets = np.log(closes / closes.shift(1)).dropna()
    hv_series = rets.rolling(21).std() * math.sqrt(TRADING_DAYS)
    hv_series = hv_series.dropna()
    if len(hv_series) < 20:
        return float("nan"), float("nan")
    lo, hi = float(hv_series.min()), float(hv_series.max())
    if hi <= lo:
        return float("nan"), float("nan")
    rank = max(0.0, min(100.0, (current_iv - lo) / (hi - lo) * 100))
    pct = float((hv_series < current_iv).mean() * 100)
    return rank, pct


def get_earnings_date(tk):
    """Returns next earnings date or None."""
    try:
        cal = tk.calendar
        if cal is None:
            return None
        if isinstance(cal, dict):
            dates = cal.get("Earnings Date", [])
            if dates:
                d = dates[0]
                return d.date() if hasattr(d, "date") else d
        if isinstance(cal, pd.DataFrame) and not cal.empty:
            for col in ("Earnings Date", "Earnings Date Start"):
                if col in cal.columns:
                    val = cal[col].iloc[0]
                    return val.date() if hasattr(val, "date") else val
            if "Earnings Date" in cal.index:
                val = cal.loc["Earnings Date"].iloc[0]
                return val.date() if hasattr(val, "date") else val
    except Exception:
        pass
    return None


def get_unusual_flow(ticker):
    """
    Fetch recent option flow from Unusual Whales API.
    Requires UNUSUAL_WHALES_API_KEY env var.
    Derives bullish/bearish bias from call vs put ask-side premium.
    Returns sentiment dict or None.
    """
    api_key = os.environ.get("UNUSUAL_WHALES_API_KEY")
    if not api_key or not HAS_REQUESTS:
        return None
    try:
        headers = {"Authorization": f"Bearer {api_key}", "Accept": "application/json"}
        resp = _requests.get(
            f"{UW_API_BASE}/api/option-flow-alerts",
            headers=headers,
            params={"ticker_symbol": ticker, "limit": 50},
            timeout=8,
        )
        if resp.status_code != 200:
            return None
        data = resp.json().get("data", []) or []
        if not data:
            return None

        bull_prem = bear_prem = 0.0
        for trade in data:
            prem = float(trade.get("premium") or 0)
            is_call = str(trade.get("type", "")).lower() == "call"
            # ask-side call = aggressive bull; ask-side put = aggressive bear
            side = str(trade.get("ask_side", trade.get("side", ""))).lower()
            is_ask = side in ("ask", "above_ask", "true", "1")
            if is_call and is_ask:
                bull_prem += prem
            elif not is_call and is_ask:
                bear_prem += prem
            elif is_call:
                bear_prem += prem * 0.5  # bid-side call could be closing
            else:
                bull_prem += prem * 0.5  # bid-side put could be closing

        total = bull_prem + bear_prem
        if total == 0:
            return None
        bull_pct = bull_prem / total * 100
        bias = "BULLISH" if bull_pct >= 60 else "BEARISH" if bull_pct <= 40 else "NEUTRAL"
        return {"bias": bias, "bull_pct": bull_pct, "n_trades": len(data)}
    except Exception:
        return None


# ---------------------------------------------------------------------------
# Backtest: iron condor win rate over past year
# ---------------------------------------------------------------------------

def backtest_iron_condor(closes, dte=35):
    """
    Walk forward over the past year, selling a ~0.20-delta strangle every DTE days.
    Uses rolling 30d HV as IV proxy to set short strikes (1.28 sigma = ~0.20 delta).
    Counts wins (price inside range all DTE days) vs losses (price touches a strike).
    Returns dict with win_rate, n_trades, avg_credit_pct, or None if too little data.
    """
    prices = closes.values
    n = len(prices)
    if n < dte * 3:
        return None

    wins = losses = 0
    credits = []
    idx = 21

    while idx + dte <= n:
        entry = prices[idx]
        log_rets = np.log(prices[idx - 20:idx] / prices[idx - 21:idx - 1])
        hv = float(np.std(log_rets) * math.sqrt(TRADING_DAYS))
        if hv <= 0:
            idx += dte
            continue

        sigma_move = entry * hv * math.sqrt(dte / TRADING_DAYS)
        upper = entry + 1.28 * sigma_move   # ~0.20 delta call strike
        lower = entry - 1.28 * sigma_move   # ~0.20 delta put strike

        t = dte / 365.0
        rfr = 0.045
        credit_per_share = (_bs_price(entry, upper, t, hv, rfr, "call")
                            + _bs_price(entry, lower, t, hv, rfr, "put"))
        credits.append(credit_per_share / entry * 100)

        window = prices[idx:idx + dte]
        if all(lower <= p <= upper for p in window):
            wins += 1
        else:
            losses += 1
        idx += dte

    total = wins + losses
    if total == 0:
        return None
    return {
        "win_rate": wins / total * 100,
        "n_trades": total,
        "avg_credit_pct": float(np.mean(credits)) if credits else 0.0,
    }


# ---------------------------------------------------------------------------
# Chain preparation
# ---------------------------------------------------------------------------

def _spread_quality(bid, ask):
    if pd.notna(bid) and pd.notna(ask) and bid > 0 and ask > 0:
        mid = (bid + ask) / 2
        pct = (ask - bid) / mid * 100
        if pct < 5:
            return "tight"
        if pct < 20:
            return "ok"
        return "wide"
    return "?"


def prepare_chain(df, spot, t_years, rfr, kind):
    df = df.copy()
    for col in ("bid", "ask", "lastPrice", "volume", "openInterest", "impliedVolatility"):
        if col not in df:
            df[col] = np.nan
    df["volume"] = df["volume"].fillna(0)
    df["openInterest"] = df["openInterest"].fillna(0)

    def midprice(row):
        b, a = row["bid"], row["ask"]
        if pd.notna(b) and pd.notna(a) and b > 0 and a >= b:
            return (b + a) / 2.0
        lp = row["lastPrice"]
        return lp if pd.notna(lp) and lp > 0 else np.nan

    df["mid"] = df.apply(midprice, axis=1)
    df["spread_quality"] = df.apply(
        lambda r: _spread_quality(r["bid"], r["ask"]), axis=1)

    greek_rows = []
    for _, row in df.iterrows():
        iv = row.get("impliedVolatility", 0) or 0
        g = bs_greeks(spot, row["strike"], t_years, iv, rfr, kind)
        greek_rows.append({
            "delta": g.get("delta"),
            "gamma": g.get("gamma"),
            "theta": g.get("theta"),
            "vega": g.get("vega"),
        })
    df = pd.concat([df, pd.DataFrame(greek_rows, index=df.index)], axis=1)
    df = df.dropna(subset=["mid", "delta"])
    df = df[df["impliedVolatility"].fillna(0) > 0.01]

    liquid = df[(df["openInterest"] >= 10) | (df["volume"] >= 5)]
    out = liquid if len(liquid) >= 5 else df
    return out.sort_values("strike").reset_index(drop=True)


# ---------------------------------------------------------------------------
# Strike selection helpers
# ---------------------------------------------------------------------------

def by_delta(df, target):
    if df.empty:
        return None
    return df.loc[(df["delta"] - target).abs().idxmin()]


def atm_row(df, spot):
    if df.empty:
        return None
    return df.loc[(df["strike"] - spot).abs().idxmin()]


def wing_row(df, short_strike, direction, steps=2):
    strikes = df["strike"].tolist()
    if short_strike not in strikes:
        return None
    idx = max(0, min(len(strikes) - 1, strikes.index(short_strike) + direction * steps))
    if strikes[idx] == short_strike:
        return None
    return df[df["strike"] == strikes[idx]].iloc[0]


def common_atm_strike(calls, puts, spot):
    common = sorted(set(calls["strike"]).intersection(set(puts["strike"])))
    if not common:
        return None
    return min(common, key=lambda k: abs(k - spot))


# ---------------------------------------------------------------------------
# Formatting helpers
# ---------------------------------------------------------------------------

def money(x):
    sign = "-" if x < 0 else ""
    return f"{sign}${abs(x):,.2f}"


def _safe(v):
    return v is not None and not (isinstance(v, float) and math.isnan(v))


def _net_greeks(*legs):
    """Sum greeks. Each leg = (sign, row). sign=+1 long, -1 short."""
    total = {"theta": 0.0, "vega": 0.0, "gamma": 0.0}
    for sign, row in legs:
        for g in total:
            v = row.get(g)
            if v is not None:
                try:
                    total[g] += sign * float(v)
                except (TypeError, ValueError):
                    pass
    return total


def _fmt_net(ng):
    # scale to per-contract (100 shares)
    parts = [
        f"θ {ng['theta']*100:+.2f}$/day",
        f"ν {money(ng['vega']*100)}/1%IV",
        f"γ {ng['gamma']:+.5f}",
    ]
    return "  |  ".join(parts)


def leg_str(action, row, expiry, kind):
    q = row.get("spread_quality", "?")
    theta = row.get("theta")
    vega = row.get("vega")
    extras = []
    if _safe(theta):
        extras.append(f"θ {theta*100:+.2f}$/day")
    if _safe(vega):
        extras.append(f"ν {money(vega*100)}/1%IV")
    greek_str = ("  " + "  ".join(extras)) if extras else ""
    return (f"   {action:<4} 1x {expiry} {row['strike']:g}{kind[0].upper()} "
            f"@ {money(row['mid'])}  "
            f"(δ {row['delta']:+.2f}{greek_str}, OI {int(row['openInterest']):,}, "
            f"spread {q})")


# ---------------------------------------------------------------------------
# Strategy builders
# ---------------------------------------------------------------------------

def covered_call(spot, calls, expiry, dte):
    row = by_delta(calls, 0.30)
    if row is None or row["strike"] <= spot:
        return None
    prem, K = row["mid"], row["strike"]
    outlay = (spot - prem) * 100
    max_profit = (K - spot + prem) * 100
    yld = prem / spot
    ann = yld * 365 / max(dte, 1)
    ng = _net_greeks((-1, row))
    return "\n".join([
        "COVERED CALL   (income / mildly bullish)",
        f"   BUY  100 shares @ {money(spot)}",
        leg_str("SELL", row, expiry, "call"),
        f"   Net outlay:     {money(outlay)}",
        f"   Max profit:     {money(max_profit)}  (called away above {K:g})",
        f"   Max loss:       {money(outlay)}  (stock to zero)",
        f"   Breakeven:      {money(spot - prem)}",
        f"   Premium yield:  {yld*100:.2f}%  ({ann*100:.1f}% annualized)",
        f"   Net greeks:     {_fmt_net(ng)}",
        f"   Prob of assign: ~{row['delta']*100:.0f}%",
    ])


def cash_secured_put(spot, puts, expiry, dte):
    row = by_delta(puts, -0.30)
    if row is None or row["strike"] >= spot:
        return None
    prem, K = row["mid"], row["strike"]
    yld = prem / K
    ann = yld * 365 / max(dte, 1)
    ng = _net_greeks((-1, row))
    return "\n".join([
        "CASH-SECURED PUT   (income / willing to buy the dip)",
        leg_str("SELL", row, expiry, "put"),
        f"   Collateral:     {money(K * 100)} cash set aside",
        f"   Max profit:     {money(prem * 100)}  (expires worthless above {K:g})",
        f"   Max loss:       {money((K - prem) * 100)}  (stock to zero)",
        f"   Breakeven:      {money(K - prem)}",
        f"   Premium yield:  {yld*100:.2f}%  ({ann*100:.1f}% annualized)",
        f"   Net greeks:     {_fmt_net(ng)}",
        f"   Prob keep prem: ~{(1 - abs(row['delta']))*100:.0f}%",
    ])


def bull_call_spread(spot, calls, expiry):
    long_row = atm_row(calls, spot)
    short_row = by_delta(calls, 0.30)
    if (long_row is None or short_row is None
            or short_row["strike"] <= long_row["strike"]):
        return None
    debit = long_row["mid"] - short_row["mid"]
    if debit <= 0:
        return None
    width = short_row["strike"] - long_row["strike"]
    max_profit = (width - debit) * 100
    if max_profit <= 0:
        return None
    ng = _net_greeks((+1, long_row), (-1, short_row))
    return "\n".join([
        "BULL CALL SPREAD   (defined-risk bullish)",
        leg_str("BUY", long_row, expiry, "call"),
        leg_str("SELL", short_row, expiry, "call"),
        f"   Net debit:      {money(debit * 100)}",
        f"   Max profit:     {money(max_profit)}  above {short_row['strike']:g}",
        f"   Max loss:       {money(debit * 100)}  below {long_row['strike']:g}",
        f"   Breakeven:      {money(long_row['strike'] + debit)}",
        f"   Reward/risk:    {max_profit / (debit * 100):.2f}x",
        f"   Net greeks:     {_fmt_net(ng)}",
    ])


def bear_put_spread(spot, puts, expiry):
    long_row = atm_row(puts, spot)
    short_row = by_delta(puts, -0.30)
    if (long_row is None or short_row is None
            or short_row["strike"] >= long_row["strike"]):
        return None
    debit = long_row["mid"] - short_row["mid"]
    if debit <= 0:
        return None
    width = long_row["strike"] - short_row["strike"]
    max_profit = (width - debit) * 100
    if max_profit <= 0:
        return None
    ng = _net_greeks((+1, long_row), (-1, short_row))
    return "\n".join([
        "BEAR PUT SPREAD   (defined-risk bearish)",
        leg_str("BUY", long_row, expiry, "put"),
        leg_str("SELL", short_row, expiry, "put"),
        f"   Net debit:      {money(debit * 100)}",
        f"   Max profit:     {money(max_profit)}  below {short_row['strike']:g}",
        f"   Max loss:       {money(debit * 100)}  above {long_row['strike']:g}",
        f"   Breakeven:      {money(long_row['strike'] - debit)}",
        f"   Reward/risk:    {max_profit / (debit * 100):.2f}x",
        f"   Net greeks:     {_fmt_net(ng)}",
    ])


def iron_condor(spot, calls, puts, expiry):
    sc = by_delta(calls, 0.20)
    sp = by_delta(puts, -0.20)
    if sc is None or sp is None:
        return None
    if not (sp["strike"] < spot < sc["strike"]):
        return None
    lc = wing_row(calls, sc["strike"], +1, steps=2)
    lp = wing_row(puts, sp["strike"], -1, steps=2)
    if lc is None or lp is None:
        return None
    credit = sc["mid"] + sp["mid"] - lc["mid"] - lp["mid"]
    if credit <= 0:
        return None
    width = max(lc["strike"] - sc["strike"], sp["strike"] - lp["strike"])
    max_loss = (width - credit) * 100
    if max_loss <= 0:
        return None
    pop = max(0.0, 1 - (sc["delta"] + abs(sp["delta"])))
    ng = _net_greeks((-1, sc), (+1, lc), (-1, sp), (+1, lp))
    return "\n".join([
        "IRON CONDOR   (defined-risk neutral, collects premium)",
        leg_str("SELL", sp, expiry, "put"),
        leg_str("BUY", lp, expiry, "put"),
        leg_str("SELL", sc, expiry, "call"),
        leg_str("BUY", lc, expiry, "call"),
        f"   Net credit:     {money(credit * 100)}",
        f"   Max profit:     {money(credit * 100)}  between {sp['strike']:g} and {sc['strike']:g}",
        f"   Max loss:       {money(max_loss)}",
        f"   Breakevens:     {money(sp['strike'] - credit)} / {money(sc['strike'] + credit)}",
        f"   Prob of profit: ~{pop*100:.0f}%",
        f"   Net greeks:     {_fmt_net(ng)}",
    ])


def long_straddle(calls, puts, spot, expiry, exp_move):
    K = common_atm_strike(calls, puts, spot)
    if K is None:
        return None
    c = calls[calls["strike"] == K].iloc[0]
    p = puts[puts["strike"] == K].iloc[0]
    debit = c["mid"] + p["mid"]
    if debit <= 0:
        return None
    ng = _net_greeks((+1, c), (+1, p))
    lines = [
        "LONG STRADDLE   (expects a big move, direction unknown)",
        leg_str("BUY", c, expiry, "call"),
        leg_str("BUY", p, expiry, "put"),
        f"   Net debit:      {money(debit * 100)}  (= max loss if pinned at {K:g})",
        f"   Breakevens:     {money(K - debit)} / {money(K + debit)}",
        f"   Needs a move:   >{money(debit)} ({debit/spot*100:.1f}%) by expiry",
        f"   Net greeks:     {_fmt_net(ng)}",
    ]
    if exp_move:
        lines.append(
            f"   Expected move:  +/- {money(exp_move)} ({exp_move/spot*100:.1f}%)")
    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Expiry selection
# ---------------------------------------------------------------------------

def choose_expiry(expiries, target_dte, explicit=None):
    today = date.today()
    if explicit:
        if explicit not in expiries:
            sys.exit(f"Expiry {explicit} not available. Choices:\n  "
                     + "\n  ".join(expiries[:14]))
        d = datetime.strptime(explicit, "%Y-%m-%d").date()
        return explicit, (d - today).days
    best, best_dte = None, None
    for e in expiries:
        dte = (datetime.strptime(e, "%Y-%m-%d").date() - today).days
        if dte < 7:
            continue
        if best is None or abs(dte - target_dte) < abs(best_dte - target_dte):
            best, best_dte = e, dte
    if best is None:
        best = expiries[-1]
        best_dte = (datetime.strptime(best, "%Y-%m-%d").date() - today).days
    return best, best_dte


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    ap = argparse.ArgumentParser(description="Options strategy scanner.")
    ap.add_argument("ticker", help="stock or ETF symbol, e.g. AAPL")
    ap.add_argument("--dte", type=int, default=35,
                    help="target days to expiry (default 35)")
    ap.add_argument("--expiry", help="exact expiry date YYYY-MM-DD")
    args = ap.parse_args()
    ticker = args.ticker.upper()

    print(f"Fetching data for {ticker} ...")
    rfr = get_risk_free_rate()
    tk, spot, hv30, hv1y, sma50, closes, expiries = fetch_underlying(ticker)
    expiry, dte = choose_expiry(expiries, args.dte, args.expiry)
    t_years = max(dte, 1) / 365.0

    chain = tk.option_chain(expiry)
    calls = prepare_chain(chain.calls, spot, t_years, rfr, "call")
    puts = prepare_chain(chain.puts, spot, t_years, rfr, "put")
    if calls.empty or puts.empty:
        sys.exit("Option chain too thin at this expiry. Try another --expiry.")

    # ATM IV and expected move
    iv_rows = [r for r in (atm_row(calls, spot), atm_row(puts, spot))
               if r is not None and pd.notna(r.get("impliedVolatility"))]
    atm_iv = float(np.mean([r["impliedVolatility"] for r in iv_rows])) if iv_rows else float("nan")
    exp_move = spot * atm_iv * math.sqrt(t_years) if not math.isnan(atm_iv) else None

    # IV / HV regime
    iv_hv = atm_iv / hv30 if hv30 and not math.isnan(atm_iv) else float("nan")
    if not math.isnan(iv_hv) and iv_hv >= 1.2:
        regime = "RICH -- options pricey vs realized vol  ->  edge: SELL premium"
    elif not math.isnan(iv_hv) and iv_hv <= 0.8:
        regime = "CHEAP -- options cheap vs realized vol  ->  edge: BUY premium"
    else:
        regime = "FAIR -- no strong IV edge; lean on directional view"

    # IV Rank / Percentile
    iv_rank, iv_pct = (get_iv_rank(closes, atm_iv)
                       if not math.isnan(atm_iv) else (float("nan"), float("nan")))
    if not math.isnan(iv_rank):
        ivr_call = ("SELL premium (IVR elevated)" if iv_rank >= 50
                    else "BUY premium (IVR depressed)")
    else:
        ivr_call = ""

    # Earnings check
    earnings_date = get_earnings_date(tk)
    expiry_date = datetime.strptime(expiry, "%Y-%m-%d").date()
    today = date.today()
    earnings_warning = None
    if earnings_date:
        days_to_earn = (earnings_date - today).days
        if earnings_date <= expiry_date:
            earnings_warning = (
                f"!! EARNINGS {earnings_date} ({days_to_earn}d) is BEFORE expiry -- "
                "IV crush risk for sellers; gap risk for both sides")
        else:
            earnings_safe = f"next earnings {earnings_date} ({days_to_earn}d) is after expiry -- OK"

    # Unusual Whales flow
    uw = get_unusual_flow(ticker)

    # Trend
    trend = "ABOVE" if spot >= sma50 else "BELOW"

    # Backtest
    bt = backtest_iron_condor(closes, dte=35)

    # -----------------------------------------------------------------------
    # Print header
    # -----------------------------------------------------------------------
    print()
    print("=" * 72)
    print(f" OPTIONS STRATEGY SCANNER -- {ticker}")
    print("=" * 72)
    print(f" Date:           {today}   Risk-free rate: {rfr*100:.2f}%")
    print(f" Spot:           {money(spot)}")
    print(f" 50d SMA:        {money(sma50)}  (trading {trend} trend)")
    print(f" Expiry:         {expiry}  ({dte} DTE)")

    if not math.isnan(atm_iv):
        print(f" ATM IV:         {atm_iv*100:.1f}%  |  "
              f"Expected move ±{money(exp_move)} ({exp_move/spot*100:.1f}%)")
    print(f" Realized vol:   30d {hv30*100:.1f}%  |  1y {hv1y*100:.1f}%")
    if not math.isnan(iv_hv):
        print(f" IV/HV(30d):     {iv_hv:.2f}x  ->  {regime}")
    if not math.isnan(iv_rank):
        print(f" IV Rank:        {iv_rank:.0f}  |  IV Pct: {iv_pct:.0f}%  ->  {ivr_call}")

    if earnings_warning:
        print(f" Earnings:       {earnings_warning}")
    elif earnings_date:
        print(f" Earnings:       {earnings_safe}")

    if uw:
        print(f" UW Flow:        {uw['bias']}  "
              f"({uw['bull_pct']:.0f}% bull / {100-uw['bull_pct']:.0f}% bear "
              f"premium, {uw['n_trades']} prints)")
    elif os.environ.get("UNUSUAL_WHALES_API_KEY"):
        print(" UW Flow:        no flow data returned for this ticker")
    else:
        print(" UW Flow:        set UNUSUAL_WHALES_API_KEY for flow sentiment")

    if bt:
        print(f" Backtest 1y:    iron condor (35 DTE, ~0.20δ) -- "
              f"win rate {bt['win_rate']:.0f}%  |  "
              f"{bt['n_trades']} trades  |  "
              f"avg credit ~{bt['avg_credit_pct']:.2f}% of spot")

    print(SEP)

    # -----------------------------------------------------------------------
    # Strategies
    # -----------------------------------------------------------------------
    builders = [
        lambda: covered_call(spot, calls, expiry, dte),
        lambda: cash_secured_put(spot, puts, expiry, dte),
        lambda: bull_call_spread(spot, calls, expiry),
        lambda: bear_put_spread(spot, puts, expiry),
        lambda: iron_condor(spot, calls, puts, expiry),
        lambda: long_straddle(calls, puts, spot, expiry, exp_move),
    ]
    shown = 0
    for build in builders:
        try:
            block = build()
        except Exception:
            block = None
        if block:
            print(block)
            print(SEP)
            shown += 1

    if shown == 0:
        print("No viable strategies found (chain too illiquid). "
              "Try a more liquid ticker or a different --expiry.")

    print("NOTES")
    print(" - Prices use bid/ask midpoints; real fills will be worse. Fees not included.")
    print(" - Greeks are Black-Scholes estimates (European, no dividend adjustment).")
    print(" - theta/vega shown per contract (100 shares).")
    print(" - Backtest uses rolling realized vol as IV proxy -- approximation only.")
    print(" - UW flow is indicative, not predictive. Not financial advice.")


